# Train Vantage - live detector wiring (OPTIONAL).
#
# Train Vantage runs fully without any of these set: it serves the map, the
# historical patterns, and the history-based probability. The live-alert layer
# (Layer 3) only activates when a detection store is configured.
#
# The default deployed state leaves these UNSET on purpose. When unset, the app
# shows a discreet banner noting that no live radio detector is wired in yet.
#
# To wire in a live feed, point the app at a Supabase project that holds a
# `detections` table (see watchtower/README and README.md for the schema).
# Set these as Vercel Project Environment Variables (not committed):

# Supabase REST URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase anon/service key used by the serverless /api/live reader.
SUPABASE_KEY=

# Shared secret the watchtower must send to POST /api/ingest (writes a detection).
INGEST_TOKEN=
